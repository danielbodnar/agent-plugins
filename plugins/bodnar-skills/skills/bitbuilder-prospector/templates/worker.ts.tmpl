/**
 * BitBuilder Proposal Preview Worker
 * Slug: {{SLUG}}
 * Business: {{BUSINESS_NAME}}
 * Client: {{CLIENT_EMAIL}}
 *
 * Owns the full lifecycle for one preview proposal:
 *   - Serves static assets from R2 under previews/{{SLUG}}/dist/
 *   - Beacon endpoint tracks review progress
 *   - CTA endpoints handle purchase, schedule, extend
 *   - Stripe webhook finalizes purchases, generates source bundle
 *   - Goodbye page + restore request post-soft-delete
 *   - Delegates state transitions to the ProposalLifecycle DO
 */

export interface Env {
  PROPOSAL: DurableObjectNamespace;
  OUTREACH: D1Database;
  BUCKET: R2Bucket;
  STRIPE_SECRET_KEY: string;
  STRIPE_WEBHOOK_SECRET: string;
  CALCOM_LINK: string;
  HOSTING_SIGNUP_LINK: string;
  PURCHASE_LINK_URL: string;
  ADMIN_TOKEN: string;
}

const SLUG = "{{SLUG}}";
const BUSINESS_NAME = "{{BUSINESS_NAME}}";
const CLIENT_EMAIL = "{{CLIENT_EMAIL}}";
const REVIEW_DWELL_MS = 60_000;
const REVIEW_SCROLL_PCT = 50;

export default {
  async fetch(request: Request, env: Env, ctx: ExecutionContext): Promise<Response> {
    const url = new URL(request.url);
    const id = env.PROPOSAL.idFromName(SLUG);
    const proposal = env.PROPOSAL.get(id);
    const state = await proposal.fetch("https://do/state").then((r) => r.json<{ state: string }>());

    // If soft-deleted or later, all paths except a few return the goodbye page
    const terminalExceptions = new Set([
      "/goodbye",
      "/goodbye/restore-request",
      "/webhook/stripe",
      "/admin/archive",
    ]);
    if (
      ["soft_deleted", "archived", "hard_deleted"].includes(state.state) &&
      !terminalExceptions.has(url.pathname)
    ) {
      return servegoodbye(env);
    }

    // Route
    switch (url.pathname) {
      case "/_beacon":
        return handleBeacon(request, proposal);
      case "/cta/purchase":
        return handlePurchase(env, proposal);
      case "/cta/schedule":
        return handleSchedule(env, proposal);
      case "/cta/extend":
        return renderExtendForm();
      case "/cta/extend/submit":
        return handleExtendSubmit(request, proposal);
      case "/purchased":
        return renderPurchasedPage(url, env);
      case "/goodbye":
        return servegoodbye(env);
      case "/goodbye/restore-request":
        return handleRestoreRequest(request, env);
      case "/webhook/stripe":
        return handleStripeWebhook(request, env, proposal, ctx);
      case "/admin/archive":
        return handleAdminArchive(request, env, proposal);
      default:
        return serveAsset(url.pathname, env);
    }
  },
};

// -----------------------------------------------------------------------------
// Static assets from R2
// -----------------------------------------------------------------------------
async function serveAsset(pathname: string, env: Env): Promise<Response> {
  const key = `previews/${SLUG}/dist${pathname === "/" ? "/index.html" : pathname}`;
  const obj = await env.BUCKET.get(key);
  if (!obj) {
    // Try directory index
    const indexKey = `previews/${SLUG}/dist${pathname.replace(/\/$/, "")}/index.html`;
    const indexObj = await env.BUCKET.get(indexKey);
    if (indexObj) return new Response(indexObj.body, { headers: contentType(indexKey) });
    return new Response("Not found", { status: 404 });
  }
  return new Response(obj.body, { headers: contentType(key) });
}

function contentType(key: string): HeadersInit {
  const ext = key.split(".").pop()?.toLowerCase();
  const map: Record<string, string> = {
    html: "text/html; charset=utf-8",
    css: "text/css; charset=utf-8",
    js: "application/javascript; charset=utf-8",
    png: "image/png",
    jpg: "image/jpeg",
    jpeg: "image/jpeg",
    webp: "image/webp",
    svg: "image/svg+xml",
    woff2: "font/woff2",
  };
  return { "Content-Type": map[ext ?? ""] ?? "application/octet-stream" };
}

// -----------------------------------------------------------------------------
// Beacon: tracks dwell_ms, scroll_pct; triggers review-confirmed transition
// -----------------------------------------------------------------------------
async function handleBeacon(request: Request, proposal: DurableObjectStub): Promise<Response> {
  if (request.method !== "POST") return new Response("Method not allowed", { status: 405 });
  const body = await request.json<{ slug: string; dwell_ms: number; scroll_pct: number }>();
  return proposal.fetch("https://do/beacon", {
    method: "POST",
    body: JSON.stringify(body),
  });
}

// -----------------------------------------------------------------------------
// CTAs
// -----------------------------------------------------------------------------
async function handlePurchase(env: Env, proposal: DurableObjectStub): Promise<Response> {
  await proposal.fetch("https://do/event", {
    method: "POST",
    body: JSON.stringify({ type: "cta_purchase_clicked" }),
  });
  return Response.redirect(env.PURCHASE_LINK_URL, 302);
}

async function handleSchedule(env: Env, proposal: DurableObjectStub): Promise<Response> {
  await proposal.fetch("https://do/transition", {
    method: "POST",
    body: JSON.stringify({ to: "scheduled" }),
  });
  return Response.redirect(env.CALCOM_LINK, 302);
}

