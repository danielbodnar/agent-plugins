  const html = `<!DOCTYPE html>
<html lang="en"><head><meta charset="utf-8"><title>Extend preview</title>
<meta name="viewport" content="width=device-width,initial-scale=1">
<script src="https://cdn.tailwindcss.com"></script></head>
<body class="bg-stone-50 min-h-screen flex items-center justify-center p-6">
<div class="max-w-md w-full bg-white rounded-lg shadow p-8">
<h1 class="text-2xl font-semibold mb-3">Extend this preview</h1>
<p class="text-stone-600 mb-6">For legal reasons, this preview will be deleted at the end of your session. Confirm your email to extend it for 5 days so you can share it with a designer or IT contact.</p>
<form method="POST" action="/cta/extend/submit" class="space-y-4">
<input name="email" type="email" required placeholder="your email" class="w-full border rounded px-3 py-2">
<button type="submit" class="w-full bg-stone-900 text-white rounded py-2 font-medium">Verify and extend</button>
</form>
</div></body></html>`;
  return new Response(html, { headers: { "Content-Type": "text/html; charset=utf-8" } });
}

async function handleExtendSubmit(request: Request, proposal: DurableObjectStub): Promise<Response> {
  const form = await request.formData();
  const email = form.get("email");
  if (typeof email !== "string" || !email.includes("@")) {
    return new Response("Invalid email", { status: 400 });
  }
  // The Access layer already proved the user controls CLIENT_EMAIL; we
  // accept that as the verification. Additional verification could send
  // a separate one-time code; for now, Access is sufficient.
  await proposal.fetch("https://do/transition", {
    method: "POST",
    body: JSON.stringify({ to: "extended", verified_email: email }),
  });
  const html = `<!DOCTYPE html>
<html><head><meta charset="utf-8"><title>Extended</title>
<script src="https://cdn.tailwindcss.com"></script></head>
<body class="bg-stone-50 min-h-screen flex items-center justify-center p-6">
<div class="max-w-md w-full bg-white rounded-lg shadow p-8 text-center">
<h1 class="text-2xl font-semibold mb-3">Extended for 5 days</h1>
<p class="text-stone-600 mb-6">The preview will remain available through ${new Date(Date.now() + 5 * 864e5).toLocaleDateString()}.</p>
<a href="/" class="text-stone-900 underline">Back to the preview</a>
</div></body></html>`;
  return new Response(html, { headers: { "Content-Type": "text/html; charset=utf-8" } });
}

