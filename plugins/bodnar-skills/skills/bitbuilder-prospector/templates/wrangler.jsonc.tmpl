{
  // Preview Worker for {{BUSINESS_NAME}} ({{SLUG}})
  "name": "prospector-{{SLUG}}",
  "account_id": "5dae265f74e6077ad674a3d855bf9853",
  "main": "worker.ts",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],

  "routes": [
    { "pattern": "{{SLUG}}.bitbuilder.cloud/*", "custom_domain": true }
  ],

  "durable_objects": {
    "bindings": [
      { "name": "PROPOSAL", "class_name": "ProposalLifecycle" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["ProposalLifecycle"] }
  ],

  "d1_databases": [
    {
      "binding": "OUTREACH",
      "database_name": "outreach",
      "database_id": "{{D1_DATABASE_ID}}"
    }
  ],

  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "bitbuilder-prospector"
    }
  ],

  "vars": {
    "PURCHASE_LINK_URL": "{{STRIPE_PAYMENT_LINK_URL}}"
  }

  // Secrets (set via `wrangler secret put`, not checked into git):
  //   STRIPE_SECRET_KEY
  //   STRIPE_WEBHOOK_SECRET
  //   CALCOM_LINK
  //   HOSTING_SIGNUP_LINK
  //   ADMIN_TOKEN
}
